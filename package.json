{
  "name": "my-epidemic-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "test:e2e": "playwright test",
    "dev:pages": "npm run build && npx wrangler pages dev dist",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=epidemic-monitor",
    "deploy:prod": "npm run build && npx wrangler pages deploy dist --project-name=epidemic-monitor --branch=main"
  },
  "dependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "deck.gl": "^9.1.0",
    "dompurify": "^3.2.0",
    "maplibre-gl": "^4.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.80.0"
  }
}
